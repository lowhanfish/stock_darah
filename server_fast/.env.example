# Environment Variables untuk Fastify Server
# ============================================

# Server
PORT=5090
NODE_ENV=development

# JWT Secret (WAJIB - gunakan string panjang untuk keamanan)
TOKEN_SECRET=your-super-secret-key-change-this-in-production

# Database MySQL
HOST_DB_MYSQL=localhost
USER_DB_MYSQL=root
PASS_DB_MYSQL=
MAIN_DB_MYSQL=stokdarah_konut
LIMIT_DB_MYSQL=10

# Main DB (untuk query lain)
MAIN_DB=stokdarah_konut

